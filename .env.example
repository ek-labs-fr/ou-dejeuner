# Office anchor used for walking-time and direction display. Used by both
# the Next.js app (lib/walking.ts) and the Python ingestion scripts.
OFFICE_LAT=48.0
OFFICE_LNG=2.0

# Google Places (NEW) API key. Restrict to Places API only and IP-allowlist.
GOOGLE_PLACES_API_KEY=

# SQLite database file path. Created on first migration.
# In production: /var/lib/oudejeuner/oudejeuner.db
DATABASE_URL=./data/oudejeuner.db

# Office gate passwords. Distributed to colleagues via Slack/email.
# Full = vote/tag/comment/submit access. Readonly = catalogue + counts only.
OFFICE_GATE_PASSWORD=
OFFICE_GATE_PASSWORD_READONLY=

# 32+ bytes of randomness used to sign the gate cookie. Generate with:
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('hex'))"
# Rotating this invalidates all existing gate cookies (everyone re-enters).
GATE_COOKIE_SECRET=
